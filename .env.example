# ===== Database Configuration =====
# Full JDBC URL — NeonDB example shown; replace with your own PostgreSQL connection string
POSTGRES_DB=jdbc:postgresql://<host>/neondb?sslmode=require
POSTGRES_USERNAME=your_db_username
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_PORT=5432

# ===== JWT Configuration =====
# Generate a secure Base64-encoded random string (minimum 256 bits)
# Example (Linux/macOS): openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here_minimum_256_bits_recommended

# ===== Email Configuration (Resend API) =====
# Sign up at https://resend.com and create an API key
# MAIL_FROM must be a verified sender address or domain on your Resend account
RESEND_API_KEY=re_your_resend_api_key_here
MAIL_FROM=noreply@yourdomain.com

# ===== Application URLs =====
# Base URL of the frontend — used to build the verification link in emails
FRONTEND_URL=http://localhost:3000
# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ===== Cloudinary Configuration =====
# Sign up at https://cloudinary.com (free tier available)
# CLOUDINARY_USERNAME is your Cloudinary cloud name
CLOUDINARY_USERNAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===== Spring Boot Configuration =====
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# ===== Port Configuration =====
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ===== Frontend API URL =====
# Injected into the Vite build — must point to the backend API base URL
VITE_API_URL=http://localhost:8080/api
