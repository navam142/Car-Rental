# ===== Database Configuration =====
POSTGRES_DB=car_rental_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_PORT=5432

# ===== JWT Configuration =====
# Generate a secure random string (at least 256 bits)
JWT_SECRET=your_jwt_secret_key_here_minimum_256_bits_recommended

# ===== Email Configuration =====
# For Gmail: Enable 2FA and create an App Password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM=noreply@carrental.com

# ===== Application URLs =====
# Frontend verification URL (where users will be redirected after clicking email link)
APP_VERIFICATION_URL=http://localhost:3000/verify-email
VERIFICATION_TOKEN_EXP_MINUTES=30

# ===== Cloudinary Configuration =====
# Sign up at https://cloudinary.com for free account
CLOUDINARY_USERNAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===== Spring Boot Configuration =====
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# ===== Port Configuration =====
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ===== Frontend API URL =====
VITE_API_URL=http://localhost:8080/api
