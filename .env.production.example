# ===== Production Environment Configuration =====

# ===== Database Configuration =====
POSTGRES_DB=car_rental_prod
POSTGRES_USER=car_rental_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD_IN_PRODUCTION
POSTGRES_PORT=5432

# ===== JWT Configuration =====
# CRITICAL: Generate a strong random secret (at least 256 bits)
# Example: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_SECURE_RANDOM_STRING_MINIMUM_256_BITS

# ===== Email Configuration =====
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_production_email@gmail.com
MAIL_PASSWORD=your_production_app_password
MAIL_FROM=noreply@yourdomain.com

# ===== Application URLs =====
# IMPORTANT: Update these to your production domain
APP_VERIFICATION_URL=https://yourdomain.com/verify-email
VERIFICATION_TOKEN_EXP_MINUTES=30

# ===== Cloudinary Configuration =====
CLOUDINARY_USERNAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===== Spring Boot Configuration =====
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false

# ===== Port Configuration =====
# In production, these are typically handled by reverse proxy
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ===== Frontend API URL =====
# Update to your production backend URL
VITE_API_URL=https://api.yourdomain.com/api

# ===== Production Notes =====
# 1. Never commit this file with real credentials
# 2. Use secrets management in production (AWS Secrets Manager, HashiCorp Vault, etc.)
# 3. Enable SSL/TLS certificates (Let's Encrypt recommended)
# 4. Set up database backups
# 5. Configure monitoring and logging
# 6. Review security headers in nginx.conf
# 7. Set up firewall rules
# 8. Use strong passwords for all services
